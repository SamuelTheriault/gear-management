# Copier ce fichier en backend/.env et remplir les vraies valeurs.
# Ne JAMAIS commiter .env — voir /security.md à la racine du repo

# --- Django ---
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de données ---
# Laisser DB_ENGINE vide en local -> fallback sqlite automatique (pratique pour développer sans MySQL).
# Remplir pour pointer vers MySQL 8.0 (Ionos) en staging/prod.
DB_ENGINE=
DB_NAME=
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=

# --- CORS (frontend Vue en dev) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
