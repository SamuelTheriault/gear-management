# Copier ce fichier en backend/.env et remplir les vraies valeurs.
# Ne JAMAIS commiter .env — voir /security.md à la racine du repo

# --- Django ---
DJANGO_SECRET_KEY=
DJANGO_DEBUG=
DJANGO_ALLOWED_HOSTS=
# En prod (Railway) : mettre le domaine *.up.railway.app fourni, avec https://, ex.
# DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_CSRF_TRUSTED_ORIGINS=

DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# --- Base de données ---
# Laisser DB_ENGINE vide en local -> fallback sqlite automatique (pratique pour développer sans MySQL).
# En prod (Railway) : remplir avec les valeurs du plugin MySQL, via des références
# de variables Railway (${{MySQL.MYSQLHOST}}, etc.) plutôt que copier les valeurs en dur.
DB_ENGINE=
DB_NAME=
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=

# --- CORS (frontend Vue en dev) ---
CORS_ALLOWED_ORIGINS=

# --- Google OAuth 2.0 (django-allauth + dj-rest-auth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URL du frontend Vue vers laquelle rediriger une fois la session Django
# établie (login) ou terminée (logout). En local : http://127.0.0.1:5173
# (dev server Vite). En prod : l'URL où le frontend est réellement hébergé.
FRONTEND_URL=

# --- Google Routes API (calcul du temps de trajet — inventory/maps.py) ---
# Clé API distincte du GOOGLE_CLIENT_ID/SECRET ci-dessus (OAuth) — projet
# Google Cloud avec facturation activée + "Routes API" activée, clé restreinte
# à cette API. Voir inventory/maps.py pour le détail des étapes. Laisser vide
# désactive simplement l'estimation automatique de trajet (fallback sur le
# réglage "durée par défaut d'un transport", voir modèle Settings).
GOOGLE_MAPS_API_KEY=
