# Vue d'ensemble des variables d'environnement du projet.
# Le fichier réellement utilisé par Django est backend/.env.example — copie-le
# en backend/.env et remplis les vraies valeurs.
# Ne JAMAIS commiter un .env — voir security.md

# --- Django ---
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de données (MySQL 8.0 - Ionos) ---
DB_ENGINE=django.db.backends.mysql
DB_NAME=
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
